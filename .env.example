# Copy this file to .env and fill in real values. Never commit .env.

# --- This service's own public URL ---
# Set this AFTER deploying, to the public HTTPS URL Railway/Fly assigns you
# (e.g. https://your-app.up.railway.app). Etsy requires https:// redirect URIs,
# so this is what makes the one-time /oauth/etsy/start authorization flow work.
PUBLIC_BASE_URL=

# --- Etsy Open API v3 ---
# Create an app at https://www.etsy.com/developers/your-apps and register
# {PUBLIC_BASE_URL}/oauth/etsy/callback as its redirect URI.
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
# Left blank initially — discovered automatically and stored in the database
# the first time you complete /oauth/etsy/start. Only set this manually if you
# already know your shop's numeric id and want to skip that discovery step.
ETSY_SHOP_ID=

# --- Shopify Admin API ---
# e.g. lwleatherworking.myshopify.com (no https://, no trailing slash)
SHOPIFY_STORE_DOMAIN=
# Create a custom app in the Shopify Dev Dashboard (dev.shopify.com/dashboard), grant it
# the needed scopes, install it on your store, then copy the Client ID and Client secret
# from the app's settings. The service exchanges these for a short-lived access token
# itself (OAuth client credentials grant) — there's no static token to copy anymore.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2025-01

# --- Sync behavior ---
# How often to poll Etsy for new receipts, in minutes
SYNC_INTERVAL_MINUTES=5
# If true, no Shopify write calls are made — everything is logged instead
DRY_RUN=false

# --- Storage ---
# Path to the SQLite database file (must be on a persistent volume in production)
DB_PATH=./data/sync.db

# --- Server ---
# Port the HTTP server (OAuth routes + /health) listens on. Railway/Fly set this
# automatically; only needed for local runs.
PORT=3000
